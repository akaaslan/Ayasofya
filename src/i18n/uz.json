  "verse_0_text": "\"Albatta, Alloh adolatga, ehson qilishga va yaqinlarga yaxshilik qilishga buyurur...\"",
  "verse_0_source": "Nahl, 90",
  "verse_1_text": "\"Albatta, bir qiyinchilik bilan bir osonlik bordir.\"",
  "verse_1_source": "Inshirah, 94:6",
  "verse_2_text": "\"Alloh sabr qiluvchilarni sevadi.\"",
  "verse_2_source": "Oli Imron, 3:146",
  "verse_3_text": "\"Rabbingizdan mag'firat so'rang, albatta U o'ta kechirimli zotdir.\"",
  "verse_3_source": "Nuh, 71:10",
  "verse_4_text": "\"Kim Allohga tavakkal qilsa, bas, U unga kifoyadir.\"",
  "verse_4_source": "Taloq, 65:3",
  "verse_5_text": "\"Namoz mo'minlarga vaqtida farz qilingandir.\"",
  "verse_5_source": "Niso, 4:103",
  "verse_6_text": "\"Biz insonni eng go'zal shaklda yaratdik.\"",
  "verse_6_source": "Tin, 95:4",
