  "verse_0_text": "«Ҳақиқат ин аст, ки Аллоҳ ба адл ва некӣ ва бахшиш ба хешовандон амр мекунад...»",
  "verse_0_source": "Наҳл, 90",
  "verse_1_text": "«Пас, албатта, бо ҳар душворӣ осоние ҳаст.»",
  "verse_1_source": "Иншироҳ, 6",
  "verse_2_text": "«Аллоҳ собиронро дӯст медорад.»",
  "verse_2_source": "Оли Имрон, 146",
  "verse_3_text": "«Аз Парвардигори худ омурзиш бихоҳед, ки Ӯ бисёр Омурзанда аст.»",
  "verse_3_source": "Нӯҳ, 10",
  "verse_4_text": "«Ҳар кӣ бар Аллоҳ таваккал кунад, Ӯ барояш кофист.»",
  "verse_4_source": "Талоқ, 3",
  "verse_5_text": "«Намоз барои мӯъминон дар вақтҳои муайяншуда фарз аст.»",
  "verse_5_source": "Нисо, 103",
  "verse_6_text": "«Мо инсонро дар беҳтарин сурат офаридем.»",
  "verse_6_source": "Тин, 4",
