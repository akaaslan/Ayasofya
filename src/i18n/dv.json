  "verse_0_text": "\"ހަމަކަށަވަރުން، ﷲ އަމުރުކުރައްވަނީ އަދުލުވެރިވުމަށާއި، އިހްސާންތެރިވުމަށާއި، ގާތްތިމާގެ މީހުންނަށް އެހީތެރިވުމަށެވެ...\"",
  "verse_0_source": "ނަޙްލް، 90",
  "verse_1_text": "\"ހަމަކަށަވަރުން، އުނދަގޫކަމާއެކު ފަސޭހަކަންވެއެވެ.\"",
  "verse_1_source": "އިންޝިރާޙް، 6",
  "verse_2_text": "\"ﷲ ލޯބިވެވޮޑިގެންވަނީ ކެތްތެރިން ދެކެއެވެ.\"",
  "verse_2_source": "އާލްޢިމްރާން، 146",
  "verse_3_text": "\"ތިޔަބައިމީހުންގެ ވެރިރަސްކަލާނގެ ހަޟްރަތުން ފާފަފުއްސެވުމަށް އެދޭށެވެ. ހަމަކަށަވަރުން، އެކަލާނގެއީ ގިނަގިނައިން ފާފަފުއްސަވާ ރަސްކަލާނގެއެވެ.\"",
  "verse_3_source": "ނޫޙް، 10",
  "verse_4_text": "\"ﷲ އަށް ވަކީލުކުރާ މީހާއަށް އެކަލާނގެ ފުދެއެވެ.\"",
  "verse_4_source": "ޠަލާޤް، 3",
  "verse_5_text": "\"ހަމަކަށަވަރުން، ނަމާދަކީ މުއުމިނުންގެ މައްޗަށް ވަގުތު ކަނޑައެޅިގެންވާ ފަރުޟެކެވެ.\"",
  "verse_5_source": "ނިސާއު، 103",
  "verse_6_text": "\"ހަމަކަށަވަރުން، ތިމަންރަސްކަލާނގެ އިންސާނާ އެންމެ ރީތި ސޫރަގައި ހެއްދެވީމެވެ.\"",
  "verse_6_source": "ތީން، 4",
