  "verse_0_text": "\"إِنَّ اللَّهَ يَأْمُرُ بِالْعَدْلِ وَالْإِحْسَانِ وَإِيتَاءِ ذِي الْقُرْبَىٰ...\"",
  "verse_0_source": "النحل، ٩٠",
  "verse_1_text": "\"فَإِنَّ مَعَ الْعُسْرِ يُسْرًا\"",
  "verse_1_source": "الشرح، ٦",
  "verse_2_text": "\"وَاللَّهُ يُحِبُّ الصَّابِرِينَ\"",
  "verse_2_source": "آل عمران، ١٤٦",
  "verse_3_text": "\"فَقُلْتُ اسْتَغْفِرُوا رَبَّكُمْ إِنَّهُ كَانَ غَفَّارًا\"",
  "verse_3_source": "نوح، ١٠",
  "verse_4_text": "\"وَمَن يَتَوَكَّلْ عَلَى اللَّهِ فَهُوَ حَسْبُهُ\"",
  "verse_4_source": "الطلاق، ٣",
  "verse_5_text": "\"إِنَّ الصَّلَاةَ كَانَتْ عَلَى الْمُؤْمِنِينَ كِتَابًا مَّوْقُوتًا\"",
  "verse_5_source": "النساء، ١٠٣",
  "verse_6_text": "\"لَقَدْ خَلَقْنَا الْإِنسَانَ فِي أَحْسَنِ تَقْوِيمٍ\"",
  "verse_6_source": "التين، ٤",
