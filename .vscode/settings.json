{
  "i18n-ally.localesPaths": ["src/i18n"],
  "i18n-ally.keystyle": "nested",
  "i18n-ally.displayLanguage": "tr",
  "i18n-ally.sourceLanguage": "tr",
  "i18n-ally.enabledFrameworks": ["react", "react-i18next"],
  "i18n-ally.extract.autoDetect": true,
  "i18n-ally.enabledParsers": ["json", "js", "ts"],
  // Regex'leri tırnak içinde şu şekilde revize edelim:
  "i18n-ally.extract.ignore": [
    "^rgba?\\(.*\\)$",
    "^#[0-9a-fA-F]{3,6}$",
    "\\.(png|jpg|jpeg|svg|gif)$" 
  ]

}