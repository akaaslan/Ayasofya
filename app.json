{
  "expo": {
    "name": "ayasofya",
    "slug": "Ayasofya",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#061e1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ayasofya.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#061e1a"
      },
      "package": "com.ayasofya.app",
      "versionCode": 5,
      "blockedPermissions": [
        "android.permission.ACTIVITY_RECOGNITION"
      ],
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "e7fd08fd-4c8a-4e30-8100-e43ed2ddef9f"
      }
    },
    "plugins": [
      "expo-sqlite",
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Uygulamanın namaz vakitlerini hesaplamak için konumunuza ihtiyacı var."
        }
      ],
      "expo-audio",
      ["expo-font", { "fonts": ["./assets/fonts/ionicons.ttf"] }]
    ]
  }
}
